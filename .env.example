# ── Groq API Key ─────────────────────────────────────────────────────────────
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Settings ─────────────────────────────────────────────────────────────
# Recommended free models: llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=8192

# ── Application Settings ──────────────────────────────────────────────────────
APP_NAME=ResearchPilot AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Backend Settings ──────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend Settings ─────────────────────────────────────────────────────────
FRONTEND_PORT=8501

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/research_pilot.db

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTORSTORE_PATH=./data/vectorstore

# ── Reports ───────────────────────────────────────────────────────────────────
REPORTS_PATH=./data/reports

# ── Papers Cache ──────────────────────────────────────────────────────────────
PAPERS_PATH=./data/papers

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ArXiv Settings ────────────────────────────────────────────────────────────
ARXIV_MAX_RESULTS=20
ARXIV_TIMEOUT=30

# ── Cache Settings ────────────────────────────────────────────────────────────
CACHE_TTL=3600
CACHE_PATH=./data/cache
